# ===== Qlib Configuration =====
QLIB_DATA_DIR=./data/qlib_data
QLIB_CACHE_DIR=./data/cache
QLIB_LOG_LEVEL=INFO

# ===== Alpha Vantage API =====
ALPHA_VANTAGE_API_KEY=your_api_key_here

# ===== EOD Historical Data API =====
EODHD_API_KEY=your_api_key_here

# ===== Intrinio API =====
INTRINIO_API_KEY=your_api_key_here

# ===== SEC EDGAR =====
SEC_EDGAR_USER_AGENT=qlib-us-fundamental/0.1.0 (your_email@example.com)

# ===== Database =====
# SQLite (development, default)
DATABASE_URL=sqlite+aiosqlite:///./data/system.db
# PostgreSQL (production) - uncomment and set credentials
# DATABASE_URL=postgresql+asyncpg://qlib_user:changeme@localhost:5432/qlib

# ===== Security =====
AES_ENCRYPTION_KEY=generate_with_openssl_rand_32_bytes
JWT_SECRET_KEY=your_jwt_secret_key_here
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ===== OIDC / SSO (optional) =====
# OIDC_ENABLED=false
# OIDC_ISSUER=https://accounts.google.com
# OIDC_CLIENT_ID=your_oidc_client_id
# OIDC_CLIENT_SECRET=your_oidc_client_secret

# ===== Environment =====
ENVIRONMENT=development
DEBUG=true
